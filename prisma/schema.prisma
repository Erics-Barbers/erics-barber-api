generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String    @id @default(cuid())
  name            String    @default("Anonymous")
  email           String    @unique
  passwordHash    String?
  role            Role      @default(CUSTOMER)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  anonymizedAt    DateTime?
  isEmailVerified Boolean   @default(false)
  mfaEnabled      Boolean   @default(false)
  mfaMethod       MfaMethod @default(EMAIL)

  // Relations
  accounts          ExternalAccount[]
  mfa               Mfa?
  mfaChallenges     MfaChallenge[]
  sessions          Session[]
  bookings          Booking[]
  cancelledBookings Booking[]         @relation("BookingCancelledBy")
  barber            Barber?
}

model Barber {
  id            String    @id @default(cuid())
  userId        String    @unique
  displayName   String    @unique
  isActive      Boolean   @default(true)
  phone         String    @unique
  createdAt     DateTime  @default(now())
  deactivatedAt DateTime?

  // Relations
  user                   User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions               Session[]
  bookings               Booking[]
  availabilityRules      BarberAvailabilityRule[]
  availabilityExceptions BarberAvailabilityException[]
}

model ExternalAccount {
  id         String   @id @default(cuid())
  provider   String
  providerId String // user id from the external IdP
  userId     String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@unique([provider, providerId])
}

model Mfa {
  id        String   @id @default(cuid())
  userId    String   @unique
  secret    String // TOTP secret
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model MfaChallenge {
  id         String    @id @default(cuid())
  userId     String
  codeHash   String
  method     MfaMethod @default(EMAIL)
  rememberMe Boolean   @default(false)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Session {
  id                  String                   @id @default(cuid())
  userId              String
  refreshToken        String                   @unique
  familyId            String                   @default(cuid())
  replacedBySessionId String?
  revokedAt           DateTime?
  revokedReason       SessionRevocationReason?
  rememberMe          Boolean                  @default(false)
  userAgent           String?
  ipAddress           String?
  expiresAt           DateTime
  createdAt           DateTime                 @default(now())
  user                User                     @relation(fields: [userId], references: [id])
  barber              Barber?                  @relation(fields: [barberId], references: [id])
  barberId            String?

  @@index([expiresAt])
  @@index([familyId])
  @@index([userId, expiresAt])
}

model Booking {
  id                String        @id @default(uuid())
  userId            String?
  customerName      String?
  customerEmail     String?
  customerPhone     String?
  serviceId         String?
  status            BookingStatus @default(CONFIRMED)
  startTime         DateTime
  endTime           DateTime
  cancelledAt       DateTime?
  cancelledByUserId String?
  createdAt         DateTime      @default(now())

  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  barber          Barber?  @relation(fields: [barberId], references: [id])
  barberId        String?
  service         Service? @relation(fields: [serviceId], references: [id])
  cancelledByUser User?    @relation("BookingCancelledBy", fields: [cancelledByUserId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([serviceId])
  @@index([cancelledByUserId])
}

model BarberAvailabilityRule {
  id          String    @id @default(cuid())
  barberId    String
  dayOfWeek   DayOfWeek
  startMinute Int
  endMinute   Int
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  barber Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([barberId, dayOfWeek, startMinute, endMinute])
  @@index([barberId, dayOfWeek])
}

model BarberAvailabilityException {
  id          String                    @id @default(cuid())
  barberId    String
  date        DateTime
  startMinute Int?
  endMinute   Int?
  type        AvailabilityExceptionType
  reason      String?
  createdAt   DateTime                  @default(now())

  barber Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@index([barberId, date])
}

model Service {
  id              String   @id @default(cuid())
  name            String   @unique
  description     String
  pricePence      Int
  durationMinutes Int
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bookings Booking[]
}

model OutboxEvent {
  id          String            @id @default(cuid())
  type        OutboxEventType
  status      OutboxEventStatus @default(PENDING)
  payload     Json
  attempts    Int               @default(0)
  lastError   String?
  availableAt DateTime          @default(now())
  processedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([status, availableAt])
  @@index([type, status])
}

enum Role {
  ADMIN
  BARBER
  CUSTOMER
}

enum MfaMethod {
  EMAIL
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum AvailabilityExceptionType {
  UNAVAILABLE
  AVAILABLE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum OutboxEventType {
  AUTH_VERIFICATION_EMAIL
  AUTH_PASSWORD_RESET_EMAIL
  AUTH_MFA_CODE_EMAIL
  BOOKING_CONFIRMATION_EMAIL
  BOOKING_UPDATED_EMAIL
  BOOKING_CANCELLED_EMAIL
}

enum OutboxEventStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}

enum SessionRevocationReason {
  ROTATED
  REPLAY_DETECTED
  ACCOUNT_DELETED
}
